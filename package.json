{
  "name": "shareview-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "db:test": "node -e \"require('./lib/db').testConnection()\"",
    "snapshots:generate": "tsx services/snapshot-generator/generate-snapshots.ts",
    "snapshots:force": "tsx services/snapshot-generator/generate-snapshots.ts --force",
    "snapshots:dry-run": "tsx services/snapshot-generator/generate-snapshots.ts --dry-run",
    "snapshots:classify": "tsx services/snapshot-classifier/classify-snapshots.ts",
    "snapshots:auctions": "tsx services/generate-auction-snapshots.ts",
    "snapshots:auctions:force": "tsx services/generate-auction-snapshots.ts --force",
    "availability:refresh": "tsx services/data-availability/refresh-data-availability.ts",
    "availability:refresh:dry-run": "tsx services/data-availability/refresh-data-availability.ts --dry-run",
    "insights:generate": "tsx services/ai-insights-generator/generate-ai-insights.ts",
    "insights:dry-run": "tsx services/ai-insights-generator/generate-ai-insights.ts --dry-run",
    "metrics:generate": "tsx services/domain-metrics-generator/generate-domain-metrics.ts",
    "metrics:force": "tsx services/domain-metrics-generator/generate-domain-metrics.ts --force",
    "metrics:dry-run": "tsx services/domain-metrics-generator/generate-domain-metrics.ts --dry-run",
    "pipeline": "tsx services/pipeline.ts",
    "pipeline:dry-run": "tsx services/pipeline.ts --dry-run",
    "benchmark:pipeline-matrix": "tsx scripts/benchmark_pipeline_matrix.ts",
    "test:user-guardrails": "tsx scripts/test_user_guardrails.ts",
    "test:overview-monthly-contract": "tsx scripts/test_overview_monthly_contract.ts",
    "audit:source-updates": "tsx scripts/audit_source_updates.ts",
    "audit:weekly-history-tagging": "tsx scripts/audit_weekly_history_tagging.ts",
    "reports:backfill-overview": "tsx scripts/backfill_report_overview_snapshots.ts",
    "retailers:sync-rsr-activity": "tsx scripts/sync_rsr_retailers_activity.ts",
    "retailers:sync-rsr-activity:dry-run": "tsx scripts/sync_rsr_retailers_activity.ts --dry-run",
    "views:sync-rsr": "tsx scripts/sync_dashboard_views_from_rsr.ts",
    "views:sync-rsr:dry-run": "tsx scripts/sync_dashboard_views_from_rsr.ts --dry-run"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/cloud-sql-connector": "^1.9.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.25",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-gauge-component": "^2.0.26",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^5.0.2",
    "@types/d3-color": "^3.1.3",
    "@types/d3-path": "^3.1.1",
    "@types/node": "^20.19.31",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
